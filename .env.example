# .env.example — copy to .env in the project root and fill in real values.
# Never commit the real .env file.

# Required — HydraDB (knowledge graph + retrieval)
HYDRA_DB_API_KEY=hdb_xxxxxxxxxxxxxxxxxxxxx
# Any name you want — this is the database this build will create in YOUR
# HydraDB account (via scripts/setup_and_ingest_sdk.py --step create), not a
# shared/existing one.
HYDRA_DB_TENANT_ID=stock-decoder

# Required — OpenAI (routing confirmation + answer synthesis)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
